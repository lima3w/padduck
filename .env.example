# Docker Compose reads .env automatically for variable interpolation.
# Copy this file to .env for local development, or set these variables on the
# deployment runner/service environment.

POSTGRES_USER=ipam
# REQUIRED: change before any shared or production deployment.
POSTGRES_PASSWORD=ipam
POSTGRES_DB=ipam

# Optional override. If unset, docker-compose.yml derives this from the
# PostgreSQL variables above.
# DATABASE_URL=postgres://ipam:ipam@db:5432/ipam

SERVER_PORT=8080
ENVIRONMENT=production

# Required for production. Generate with:
# openssl rand -hex 32
MFA_ENCRYPTION_KEY=

# Empty ADMIN_PASSWORD makes the app generate the initial admin password.
ADMIN_PASSWORD=
RESET_ADMIN_PASSWORD=false

# Comma-separated list of trusted proxy IPs/CIDRs for X-Real-IP forwarding.
# TRUSTED_PROXIES=127.0.0.1

# Maximum concurrent network scan jobs.
# SCAN_MAX_CONCURRENT_JOBS=5

# Optional build metadata shown by update checks.
# APP_VERSION=v1.14.0
# GIT_COMMIT=
# BUILD_DATE=
