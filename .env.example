# Docker Compose reads .env automatically for variable interpolation. Copy this
# file to .env and fill in the required values before starting the stack.

# REQUIRED — the stack will refuse to start without this.
# Use a strong randomly generated password:
#   openssl rand -base64 32
# Special characters are fine — the backend builds the connection URL itself
# and percent-encodes the password automatically.
POSTGRES_PASSWORD=change_me_strong_password_here

# POSTGRES_USER=padduck
# POSTGRES_DB=padduck

# Optional override. If unset, the backend builds the connection string from
# the PostgreSQL variables above. Only set this for a fully custom connection
# string (e.g. an external database) — if you do, any special characters in
# the userinfo (username/password) must be percent-encoded yourself.
# DATABASE_URL=postgres://padduck:<password>@db:5432/padduck

# SERVER_PORT=8080
# ENVIRONMENT=production

# Log verbosity: warn (default — warnings and errors only), info (adds
# operational logging such as scan job lifecycle), debug, or error.
# LOG_LEVEL=warn

# Optional override. If unset, the backend creates a persistent key in
# ./data/backend/mfa-encryption-key on first startup. Generate with:
#   openssl rand -hex 32
# MFA_ENCRYPTION_KEY=

# Empty ADMIN_PASSWORD makes the app generate the initial admin password on first
# startup. Set RESET_ADMIN_PASSWORD=true to rotate it without wiping the database.
# ADMIN_PASSWORD=
# RESET_ADMIN_PASSWORD=false

# Session cookie security. Accepted values:
#   true  — Secure + SameSite=None (required when the UI is served from a different
#            origin than the API, e.g. a separate CDN in front of the app).
#   false — NOT Secure; only acceptable for local dev over plain HTTP.
#   (unset, default) — auto-detected: Secure when X-Forwarded-Proto is "https".
# SESSION_COOKIE_SECURE=

# Host port the UI is exposed on (default: 3000).
# FRONTEND_PORT=3000

# Network interface the frontend port binds to. Defaults to 127.0.0.1 (loopback
# only) — place a TLS-terminating reverse proxy in front for production access.
# Set to 0.0.0.0 only if you have another layer of network-level access control.
# FRONTEND_BIND=127.0.0.1

# Comma-separated list of trusted proxy IPs/CIDRs for X-Real-IP forwarding.
# TRUSTED_PROXIES=127.0.0.1

# Maximum concurrent network scan jobs.
# SCAN_MAX_CONCURRENT_JOBS=5

# Image tag for backend and frontend. Defaults to the pinned release in
# docker-compose.yml. To upgrade to a new release, set this to the new tag and
# run: docker compose pull && docker compose up -d
# IMAGE_TAG=1.31.25

# Optional build metadata shown by update checks.
# APP_VERSION=v1.31.24
# GIT_COMMIT=
# BUILD_DATE=
