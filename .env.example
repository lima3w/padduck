# Docker Compose reads .env automatically for variable interpolation. Defaults
# are built into docker-compose.yml; uncomment a value only when you want to
# override the default.

# POSTGRES_USER=padduck
# POSTGRES_PASSWORD=padduck
# POSTGRES_DB=padduck

# Optional override. If unset, docker-compose.yml derives this from the
# PostgreSQL variables above.
# DATABASE_URL=postgres://padduck:padduck@db:5432/padduck

# SERVER_PORT=8080
# ENVIRONMENT=production

# Optional override. If unset, the backend creates a persistent key in
# ./data/backend/mfa-encryption-key on first startup. Generate with:
# openssl rand -hex 32
# MFA_ENCRYPTION_KEY=

# Empty ADMIN_PASSWORD makes the app generate the initial admin password.
# ADMIN_PASSWORD=
# RESET_ADMIN_PASSWORD=false

# Comma-separated list of trusted proxy IPs/CIDRs for X-Real-IP forwarding.
# TRUSTED_PROXIES=127.0.0.1

# Maximum concurrent network scan jobs.
# SCAN_MAX_CONCURRENT_JOBS=5

# Optional build metadata shown by update checks.
# APP_VERSION=v1.14.0
# GIT_COMMIT=
# BUILD_DATE=
